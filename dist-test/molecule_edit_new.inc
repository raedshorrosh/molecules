<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css" crossorigin="anonymous">
    <title>ChemConnect Studio</title>
    <style>
      body, html {
        overscroll-behavior: none;
        touch-action: none;
      }
    </style>
    <script type="module" crossorigin>
(function(){
  function d(str) {
    return decodeURIComponent(atob(str).split('').map(function(c) {
      return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
    }).join(''));
  }
  function init() {
    var script = document.createElement('script');
    script.type = "module";
    script.textContent = d("");
    document.body.appendChild(script);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
    <script>
(function(){
  function d(str) {
    return decodeURIComponent(atob(str).split('').map(function(c) {
      return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
    }).join(''));
  }
  var style = document.createElement('style');
  style.textContent = d("");
  document.head.appendChild(style);
})();
</script>
  <script src="/_aistudio-iframe.js"></script></head>
  <body>
    <div id="stack-design-param" style="display:none;">{#design#}</div>
    <div id="stack-ta-param" style="display:none;">{#ta#}</div>
    <div id="stack-preload-param" style="display:none;">{#preload#}</div>
    <div id="stack-fixed-param" style="display:none;">{#fixed#}</div>
    <div id="stack-lang-param" style="display:none;">{#lang#}</div>
    <div id="root"></div>
    <script>
      // Load STACK JS injected script manually to avoid bundler issues
      window.addEventListener('load', function() {
        try {
          // In Moodle STACK, this gets replaced with the actual URL
          var corsUrl = '[[cors src="stackjsiframe.js"/]]';
          // If it hasn't been replaced, we are not in STACK
          if (corsUrl.indexOf('[[cors') > -1) {
             console.log("Not running in a STACK environment. Normal mode active.");
             return;
          }
          
          import(corsUrl).then(function(module) {
            var stack_js = module.stack_js || window.stack_js || module.default;
            if (stack_js) {
              var urlParams = new URLSearchParams(window.location.search);
              var inputName = urlParams.get('input') || "ans1";
              stack_js.request_access_to_input(inputName, true).then(function(inputId) {
                var hiddenInput = document.getElementById(inputId);
                window.__stackInput = hiddenInput;
                
                if (hiddenInput && hiddenInput.value) {
                  window.dispatchEvent(new CustomEvent('stack-load-molecule', { detail: hiddenInput.value }));
                }

                window.dispatchEvent(new Event('stack-environment-detected'));

                window.addEventListener('molecule-changed', function(e) {
                  if (hiddenInput) {
                    hiddenInput.value = JSON.stringify(e.detail);
                    hiddenInput.dispatchEvent(new Event('change'));
                  }
                });
              }).catch(function(err) {
                console.warn("STACK integration initialization failed.", err);
              });
            }
          }).catch(function(err) {
             // Fallback to classic script tag
             console.warn("Dynamic import failed, trying classic script:", err);
             var script = document.createElement('script');
             script.src = corsUrl;
             script.onload = function() {
               if (window.stack_js) {
                  var urlParams = new URLSearchParams(window.location.search);
                  var inputName = urlParams.get('input') || "ans1";
                  window.stack_js.request_access_to_input(inputName, true).then(function(inputId) {
                    var hiddenInput = document.getElementById(inputId);
                    window.__stackInput = hiddenInput;
                    if (hiddenInput && hiddenInput.value) {
                      window.dispatchEvent(new CustomEvent('stack-load-molecule', { detail: hiddenInput.value }));
                    }
                    window.dispatchEvent(new Event('stack-environment-detected'));
                    window.addEventListener('molecule-changed', function(e) {
                      if (hiddenInput) {
                        hiddenInput.value = JSON.stringify(e.detail);
                        hiddenInput.dispatchEvent(new Event('change'));
                      }
                    });
                  }).catch(function(err) {
                    console.warn("STACK integration initialization failed.", err);
                  });
               }
             };
             document.head.appendChild(script);
          });
        } catch (e) {
          console.log("Not running in STACK environment.", e);
        }
      });
    </script>
  </body>
</html>

